# Server-side only — never exposed to the browser
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Stripe payment link for Nexi Blueprint ($197 one-time)
VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/your_payment_link_here

# Public app URL (used to build Stripe success/cancel redirect URLs)
VITE_APP_URL=https://nexteam-studio-production.up.railway.app
PUBLIC_BASE_URL=https://nexteam-studio-staging.up.railway.app
STAGING_BASE_URL=https://nexteam-studio-staging.up.railway.app

# M2 Stripe invoice rail. Test mode only in staging; never commit real values.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Calendly or booking link shown on the success screen
VITE_BOOKING_LINK=https://calendly.com/your_link_here

# Njord / Mission Control (Aquatrace case-study)
RESEND_API_KEY=re_your_resend_api_key_here
# Sender address — must be a Resend-verified domain, or use onboarding@resend.dev for initial testing
RESEND_FROM_EMAIL=onboarding@resend.dev
VITE_NJORD_TEST_EMAIL=chris@aquatraceleak.com
VITE_ADMIN_PASSWORD=your_admin_password_here

# Gmail OAuth2 for VGB send path
GOOGLE_REDIRECT_URI=http://127.0.0.1:5173/auth/google/callback
GMAIL_SEND_FROM=service@yourdomain.com

# Bragi Telegram approval workflow
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHRIS_CHAT_ID=your_telegram_chat_id_here
BRAGI_TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret_here

# CompanyCam read-only access
COMPANYCAM_API_TOKEN=your_companycam_api_token_here
