# Server-side only — never exposed to the browser
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Stripe payment link for Nexi Blueprint ($197 one-time)
VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/your_payment_link_here

# Public app URL (used to build Stripe success/cancel redirect URLs)
VITE_APP_URL=https://nexteam-studio-production.up.railway.app

# Calendly or booking link shown on the success screen
VITE_BOOKING_LINK=https://calendly.com/your_link_here
