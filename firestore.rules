rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isChrisAdmin() {
      return request.auth != null
        && (
          request.auth.token.email == "chris1bata@gmail.com"
          || request.auth.token.roles.hasAny(["platform_operator"])
          || request.auth.token.platform_operator == true
        );
    }

    match /admin/{document=**} {
      allow read, write: if isChrisAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

