rules_version = '2';

// NexTeam-Studio Firestore Security Rules
//
// STATUS: DRAFT - not yet deployed
//
// IMPORTANT:
// - `server.js` still uses the Firebase CLIENT SDK for some backend writes, so
//   these rules would apply to those writes if deployed as-is.
// - Tenant-scoped foundation collections now assume real tenant isolation using
//   `request.auth.token.tenantId` or a platform-operator role claim.
// - Deploy these only once auth/custom-claim wiring is ready for the affected
//   surfaces, or migrate backend writes to the Admin SDK first.
//
// COLLECTION MAP:
//   agentSessions/{sessionId}
//   tenants/{tenantId}
//   tenants/{tenantId}/intakePackets/{packetId}
//   tenants/{tenantId}/config/{configId}
//   tenants/{tenantId}/runtimeSummary/{summaryId}
//   tenants/{tenantId}/subagents/{subagentId}
//   tenants/{tenantId}/sops/{sopId}
//   tenants/{tenantId}/blueprints/{blueprintId}
//   tenants/{tenantId}/onboardingSessions/{sessionId}
//   clientOrganizations/{clientId}
//   clientOrganizations/{clientId}/members/{userId}
//   clientOrganizations/{clientId}/invites/{inviteId}
//   clientOrganizations/{clientId}/deliveryState/{stateId}
//   njordSessions/{sessionId}
//   njordSessions/{sessionId}/events/{eventId}
//   njordCampaignLogs/{logId}

service cloud.firestore {
  match /databases/{database}/documents {

    match /agentSessions/{sessionId} {
      allow read: if isPlatformOperator() || isAgentSessionOwner(resource.data);
      allow create: if canWriteOwnAgentSession(request.resource.data);
      allow update: if isPlatformOperator()
                    || (isAgentSessionOwner(resource.data) && canWriteOwnAgentSession(request.resource.data));
      allow delete: if false;
    }

    match /tenants/{tenantId} {
      allow read: if canAccessTenant(tenantId);
      allow create, update: if canAccessTenant(tenantId)
                            && isValidTenantRootWrite(request.resource.data, tenantId);
      allow delete: if false;
    }

    match /tenants/{tenantId}/intakePackets/{packetId} {
      allow read: if canAccessTenant(tenantId);
      allow create, update: if canAccessTenant(tenantId)
                            && isValidIntakePacketWrite(request.resource.data, tenantId);
      allow delete: if false;
    }

    match /tenants/{tenantId}/config/{configId} {
      allow read: if canAccessTenant(tenantId);
      allow create, update: if canAccessTenant(tenantId)
                            && isValidTenantConfigWrite(request.resource.data, tenantId);
      allow delete: if false;
    }

    match /tenants/{tenantId}/runtimeSummary/{summaryId} {
      allow read: if canAccessTenant(tenantId);
      allow create, update: if canAccessTenant(tenantId)
                            && isValidRuntimeSummaryWrite(request.resource.data, tenantId);
      allow delete: if false;
    }

    match /tenants/{tenantId}/subagents/{subagentId} {
      allow read: if canAccessTenant(tenantId);
      allow create, update: if canAccessTenant(tenantId)
                            && isValidSubagentWrite(request.resource.data);
      allow delete: if false;
    }

    match /tenants/{tenantId}/sops/{sopId} {
      allow read: if canAccessTenant(tenantId);
      allow create: if canAccessTenant(tenantId) && isValidSOPWrite(request.resource.data, tenantId);
      allow update: if canAccessTenant(tenantId) && isValidSOPWrite(request.resource.data, tenantId);
      allow delete: if false;
    }

    match /tenants/{tenantId}/blueprints/{blueprintId} {
      allow read: if canAccessTenant(tenantId);
      allow create: if canAccessTenant(tenantId) && isValidBlueprintWrite(request.resource.data, tenantId);
      allow update: if canAccessTenant(tenantId) && isValidBlueprintWrite(request.resource.data, tenantId);
      allow delete: if false;
    }

    match /tenants/{tenantId}/onboardingSessions/{sessionId} {
      allow read: if canAccessTenant(tenantId);
      allow create: if canAccessTenant(tenantId) && isValidOnboardingSession(request.resource.data, tenantId);
      allow update: if canAccessTenant(tenantId) && isValidOnboardingSession(request.resource.data, tenantId);
      allow delete: if false;
    }

    match /clientOrganizations/{clientId} {
      allow read: if request.auth != null && isPortalMember(database, clientId, request.auth.uid);
      allow create: if isValidClientOrgCreate(request.resource.data);
      allow update: if isValidClientOrgUpdate(request.resource.data)
                    || (request.auth != null && isPortalAdmin(database, clientId, request.auth.uid));
      allow delete: if false;
    }

    match /clientOrganizations/{clientId}/members/{userId} {
      allow read: if request.auth != null
                  && (request.auth.uid == userId
                      || isPortalMember(database, clientId, request.auth.uid));
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    match /clientOrganizations/{clientId}/invites/{inviteId} {
      allow read: if (request.auth != null && isPortalMember(database, clientId, request.auth.uid))
                  || request.auth == null;
      allow create: if isValidInviteCreate(request.resource.data);
      allow update: if isValidInviteActivation(request.resource.data);
      allow delete: if false;
    }

    match /clientOrganizations/{clientId}/deliveryState/{stateId} {
      allow read: if request.auth != null && isPortalMember(database, clientId, request.auth.uid);
      allow create: if isValidDeliveryStateCreate(request.resource.data);
      allow update: if isValidDeliveryStateCreate(request.resource.data);
      allow delete: if false;
    }

    // Njord logs remain case-study scoped until that lane is generalized.
    match /njordSessions/{sessionId} {
      allow read: if request.auth != null;
      allow create, update: if isValidNjordSession(request.resource.data);
      allow delete: if false;
    }

    match /njordSessions/{sessionId}/events/{eventId} {
      allow read: if request.auth != null;
      allow create: if isValidNjordEvent(request.resource.data);
      allow update: if false;
      allow delete: if false;
    }

    match /njordCampaignLogs/{logId} {
      allow read: if request.auth != null;
      allow create: if isValidNjordCampaignLog(request.resource.data);
      allow update: if false;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }

    function isSafeTenantId(tenantId) {
      return tenantId is string
          && tenantId.size() > 0
          && tenantId.size() <= 64
          && tenantId.matches('^[a-z0-9]+(?:-[a-z0-9]+)*$');
    }

    function isPlatformOperator() {
      return request.auth != null
          && request.auth.token.keys().hasAny(["role"])
          && request.auth.token.role is string
          && request.auth.token.role in ["nexteam_admin", "platform_operator"];
    }

    function isPublicSession() {
      return request.auth != null
          && request.auth.token.keys().hasAny(["publicSession"])
          && request.auth.token.publicSession == true;
    }

    function isTenantActor(tenantId) {
      return request.auth != null
          && !isPublicSession()
          && request.auth.token.keys().hasAny(["tenantId"])
          && request.auth.token.tenantId is string
          && request.auth.token.tenantId == tenantId;
    }

    function canAccessTenant(tenantId) {
      return isSafeTenantId(tenantId) && (isPlatformOperator() || isTenantActor(tenantId));
    }

    function isValidAgentSession(data) {
      return data.keys().hasAll(["sessionId", "tenantId", "status", "ownerUid"])
          && data.sessionId is string
          && data.sessionId.size() > 0
          && data.sessionId.size() < 128
          && data.tenantId is string
          && isSafeTenantId(data.tenantId)
          && data.ownerUid is string
          && data.ownerUid.size() > 0
          && data.status in ["in_progress", "completed", "error"];
    }

    function isAgentSessionOwner(data) {
      return request.auth != null
          && data.keys().hasAny(["ownerUid"])
          && data.ownerUid is string
          && data.ownerUid == request.auth.uid;
    }

    function canWriteOwnAgentSession(data) {
      return request.auth != null
          && isValidAgentSession(data)
          && data.ownerUid == request.auth.uid;
    }

    function isValidTenantRootWrite(data, tenantId) {
      return data.keys().hasAll(["tenantId", "brandName", "avatarName", "industry"])
          && data.tenantId == tenantId
          && data.brandName is string
          && data.brandName.size() >= 2
          && data.avatarName is string
          && data.avatarName.size() >= 2
          && data.industry is string
          && data.industry.size() >= 2;
    }

    function isValidIntakePacketWrite(data, tenantId) {
      return data.keys().hasAll(["documentType", "tenantId", "packetId", "submittedAt", "intake", "meta"])
          && data.documentType == "tenant-intake-packet"
          && data.tenantId == tenantId
          && data.packetId is string
          && data.packetId.size() > 0
          && data.intake is map
          && data.meta is map;
    }

    function isValidTenantConfigWrite(data, tenantId) {
      return data.keys().hasAll(["documentType", "tenantId", "profile", "branding", "businessRules", "channels", "workflow", "dashboard", "meta"])
          && data.documentType == "tenant-client-config"
          && data.tenantId == tenantId
          && data.profile is map
          && data.branding is map
          && data.businessRules is map
          && data.channels is map
          && data.workflow is map
          && data.dashboard is map
          && data.meta is map;
    }

    function isValidRuntimeSummaryWrite(data, tenantId) {
      return data.keys().hasAll(["documentType", "tenantId", "brandName", "publicAgentName", "workflow", "connectivity", "dashboard", "updatedAt"])
          && data.documentType == "tenant-runtime-summary"
          && data.tenantId == tenantId
          && data.brandName is string
          && data.publicAgentName is string
          && data.workflow is map
          && data.connectivity is map
          && data.dashboard is map;
    }

    function isValidSubagentWrite(data) {
      return data.keys().hasAll(["id", "name", "role", "enabled"])
          && data.id is string
          && data.id.size() > 0
          && data.name is string
          && data.role is string
          && data.enabled is bool;
    }

    function isValidSOPWrite(data, tenantId) {
      return data.keys().hasAll(["title", "state", "category"])
          && data.title is string
          && data.title.size() >= 3
          && data.title.size() < 256
          && data.state in ["draft", "review", "approved", "archived"]
          && data.category in [
               "intake", "follow-up", "campaign", "quality-check",
               "onboarding", "reporting", "escalation", "maintenance"
             ]
          && (!data.keys().hasAny(["tenantId"]) || data.tenantId == tenantId);
    }

    function isValidBlueprintWrite(data, tenantId) {
      return data.keys().hasAll(["name", "state"])
          && data.name is string
          && data.name.size() >= 3
          && data.name.size() < 256
          && data.state in ["draft", "active", "archived"]
          && (!data.keys().hasAny(["tenantId"]) || data.tenantId == tenantId);
    }

    function isValidOnboardingSession(data, tenantId) {
      return data.keys().hasAll(["clientId", "blueprintId", "state"])
          && data.clientId is string
          && data.clientId.size() > 0
          && data.blueprintId is string
          && data.blueprintId.size() > 0
          && data.state in ["pending", "active", "complete", "cancelled"]
          && (!data.keys().hasAny(["tenantId"]) || data.tenantId == tenantId);
    }

    function isValidClientOrgCreate(data) {
      return data.keys().hasAll(["clientId", "slug", "purchaseStatus"])
          && data.clientId is string
          && data.clientId.size() > 0
          && data.slug is string
          && data.slug.size() > 0
          && data.purchaseStatus in ["paid", "pending", "failed", "refunded"];
    }

    function isValidClientOrgUpdate(data) {
      return data.keys().hasAny(["updatedAt", "portalStatus", "onboardingStatus"]);
    }

    function isValidInviteCreate(data) {
      return data.keys().hasAll(["token", "email", "status", "source"])
          && data.token is string
          && data.token.size() > 0
          && data.email is string
          && data.email.size() > 0
          && data.status == "pending"
          && data.source == "stripe_webhook_backend";
    }

    function isValidInviteActivation(data) {
      return data.keys().hasAll(["status"])
          && data.status == "accepted";
    }

    function isValidDeliveryStateCreate(data) {
      return data.keys().hasAll(["clientId", "currentStage"])
          && data.clientId is string
          && data.clientId.size() > 0;
    }

    function isValidNjordSession(data) {
      return data.keys().hasAll(["sessionId", "tenantId"])
          && data.sessionId is string
          && data.sessionId.size() > 0
          && data.tenantId is string
          && data.tenantId == "aquatrace-case-study";
    }

    function isValidNjordEvent(data) {
      return data.keys().hasAll(["type", "tenantId"])
          && data.type is string
          && data.type.size() > 0
          && data.tenantId == "aquatrace-case-study";
    }

    function isValidNjordCampaignLog(data) {
      return data.keys().hasAll(["tenantId"])
          && data.tenantId == "aquatrace-case-study";
    }

    function isPortalMember(database, clientId, uid) {
      return exists(/databases/$(database)/documents/clientOrganizations/$(clientId)/members/$(uid));
    }

    function isPortalAdmin(database, clientId, uid) {
      let member = get(/databases/$(database)/documents/clientOrganizations/$(clientId)/members/$(uid));
      return member.data.role in ["client_admin", "nexteam_admin"];
    }
  }
}
